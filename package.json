{
  "name": "azerothcore-startos",
  "scripts": {
    "gen": "node scripts/gen-variant.js",
    "build": "npm run gen && rm -rf ./javascript && ncc build startos/index.ts -o ./javascript",
    "prettier": "prettier --write startos",
    "check": "npm run gen && tsc --noEmit"
  },
  "dependencies": {
    "@start9labs/start-sdk": "1.5.2",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@vercel/ncc": "^0.38.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true
  },
  "version": "1.1.0",
  "description": "StartOS package for AzerothCore, a WoW 3.3.5a (Wrath of the Lich King) server emulator.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwsantiago/azerothcore-startos.git"
  },
  "keywords": [
    "wow",
    "azerothcore",
    "wotlk",
    "startos"
  ],
  "author": "kwsantiago",
  "license": "MIT",
  "type": "commonjs"
}
